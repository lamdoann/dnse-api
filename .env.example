# DNSE OpenAPI credentials (tạo tại https://developers.dnse.com.vn)
DNSE_API_KEY=
DNSE_API_SECRET=

# Dùng cho ví dụ đặt lệnh
DNSE_EMAIL=
DNSE_ACCOUNT_NO=
DNSE_OTP_CODE=

# Market data realtime (MQTT/WebSocket) — auth JWT, khác với HMAC ở trên
DNSE_USERNAME=
DNSE_PASSWORD=
# Hoặc truyền sẵn JWT nếu đã có:
DNSE_INVESTOR_ID=
DNSE_TOKEN=

# Bật log wire-level (cẩn thận: lộ chữ ký)
# DNSE_TRACE=true
